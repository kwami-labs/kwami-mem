# Required — Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key

# Qdrant connection (optional — defaults to in-memory for development)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Configuration (all optional)
KWAMI_COLLECTION=kwami_memory
KWAMI_EMBEDDING_MODEL=gemini-embedding-2-preview
KWAMI_EMBEDDING_DIMS=768
KWAMI_WORKING_MEMORY=20
KWAMI_SEARCH_LIMIT=10
KWAMI_USER_ID=default
